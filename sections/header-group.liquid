<style>
  .header-group {
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    background: #fff;
  }

  .header-group-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .header-group-brand {
    color: inherit;
    text-decoration: none;
    font-size: 1.125rem;
    font-weight: 700;
  }

  .header-group-tagline {
    margin: 0;
    color: rgba(0, 0, 0, 0.65);
  }

  @media screen and (max-width: 749px) {
    .header-group-inner {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>

<header class="header-group" role="banner">
  <div class="header-group-inner">
    <a class="header-group-brand" href="{{ routes.root_url }}">{{ shop.name }}</a>

    {%- if section.settings.tagline != blank -%}
      <p class="header-group-tagline">{{ section.settings.tagline }}</p>
    {%- endif -%}
  </div>
</header>

{% schema %}
{
  "name": "Header group",
  "tag": "section",
  "class": "section section-header-group",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline"
    }
  ],
  "presets": [
    {
      "name": "Header group"
    }
  ]
}
{% endschema %}
